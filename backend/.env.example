# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง
# (.env อยู่ใน .gitignore แล้ว ห้าม commit เด็ดขาด)

# ===== OpenRouter (LLM Gateway) =====
# สมัครและสร้าง key ที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ค่า default ของ model — เปลี่ยนได้ตามต้องการ
DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor

# ===== ChromaDB (RAG) =====
CHROMA_DB_PATH=./chroma_db

# ===== App =====
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
